# TrustLens AI — environment variables (copy to `.env` and fill in)

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false

# MySQL (use MYSQL_URL or individual fields)
# MYSQL_URL=mysql://user:pass@host:3306/dbname
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=trustlens_ai

# ── Grok / xAI (server-side only — never commit real keys) ────────────────────
# Create a key at https://x.ai/api — the app reads this only on the backend.
GROK_API_KEY=
# Optional overrides (defaults work for most setups)
# GROK_API_BASE=https://api.x.ai/v1
# GROK_MODEL=grok-2-latest

# Legacy alias also supported:
# XAI_API_KEY=
